---
import { marked } from 'marked';
import Layout from '../../../layouts/Layout.astro';
import { articles } from '../../../data/blog-en';

export function getStaticPaths() {
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

const { article } = Astro.props;
const renderedContent = article.content ? await marked(article.content) : null;
---

<Layout title={`Sinan.AI - ${article.title}`}>
  <div class="max-w-6xl mx-auto px-4 py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
    <div class="mb-10 animate-fade-in">
      <a
        href="/en/blog"
        class="text-slate-500 hover:text-emerald-400 text-sm font-medium transition-colors duration-200 inline-flex items-center gap-1 mb-8"
      >
        ← Back to Blog
      </a>

      <div class="flex flex-wrap gap-2 mb-6">
        {
          article.tags.map((tag) => (
            <span class="bg-slate-800 text-emerald-400/80 text-xs px-2 py-1 rounded-md font-mono">
              {tag}
            </span>
          ))
        }
      </div>

      <h1
        class="text-3xl md:text-4xl font-bold text-white leading-tight mb-8"
      >
        {article.title}
      </h1>

      <div class="border-b border-slate-800 mb-10"></div>
    </div>

    {
      renderedContent ? (
        <div
          class="prose-blog"
          set:html={renderedContent}
        />
      ) : (
        <div class="text-center py-20 space-y-4">
          <div class="text-4xl text-slate-700">✦</div>
          <p class="text-slate-500 text-lg">This article is coming soon.</p>
          <a
            href="/en/blog"
            class="inline-block text-blue-400 hover:text-emerald-400 text-sm font-medium transition-colors duration-200"
          >
            ← Back to Blog
          </a>
        </div>
      )
    }
    </div>
  </div>
</Layout>

<style is:global>
  .prose-blog {
    color: rgb(148 163 184);
    line-height: 1.8;
    font-size: 1rem;
  }

  .prose-blog p {
    margin-bottom: 1.5rem;
  }

  .prose-blog strong {
    color: rgb(255 255 255);
    font-weight: 700;
  }

  .prose-blog em {
    color: rgb(167 243 208);
    font-style: italic;
  }

  .prose-blog code {
    background: rgb(30 41 59);
    color: rgb(52 211 153);
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-family: 'JetBrains Mono', monospace;
  }

  .prose-blog h2 {
    color: rgb(255 255 255);
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .prose-blog h3 {
    color: rgb(226 232 240);
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose-blog ul, .prose-blog ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .prose-blog li {
    margin-bottom: 0.5rem;
  }

  .prose-blog ul li {
    list-style-type: disc;
  }

  .prose-blog ol li {
    list-style-type: decimal;
  }

  .prose-blog blockquote {
    border-left: 3px solid rgb(52 211 153);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: rgb(100 116 139);
    font-style: italic;
  }

  .prose-blog a {
    color: rgb(96 165 250);
    text-decoration: underline;
    transition: color 0.2s;
  }

  .prose-blog a:hover {
    color: rgb(52 211 153);
  }
</style>
