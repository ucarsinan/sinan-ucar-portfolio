---
import Layout from '../../layouts/Layout.astro';
import { articles } from '../../data/blog-en';
---

<Layout title="Sinan.AI - Blog">
  <div class="max-w-6xl mx-auto px-4 py-12 md:py-16">
    <div class="text-center mb-16 space-y-4 animate-fade-in">
      <h1
        class="text-4xl md:text-5xl font-bold bg-gradient-to-r from-blue-400 via-purple-400 to-emerald-400 text-transparent bg-clip-text pb-2"
      >
        Blog
      </h1>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        Thoughts on AI Engineering, Solutions Architecture, and building modern software.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        articles.map((article) => (
          <a
            href={`/en/blog/${article.slug}`}
            class="group bg-slate-900/80 border border-slate-800 rounded-2xl p-6 flex flex-col gap-4 hover:border-emerald-500/30 transition-all duration-300"
          >
            <div class="flex flex-wrap gap-2">
              {article.tags.map((tag) => (
                <span class="bg-slate-800 text-emerald-400/80 text-xs px-2 py-1 rounded-md font-mono">
                  {tag}
                </span>
              ))}
            </div>

            <h2 class="text-lg font-bold text-white leading-snug group-hover:text-emerald-400 transition-colors duration-200">
              {article.title}
            </h2>

            <p class="text-slate-400 text-sm leading-relaxed flex-1">{article.excerpt}</p>

            <span class="text-blue-400 group-hover:text-emerald-400 text-sm font-medium transition-colors duration-200 mt-auto">
              {article.content ? 'Read more →' : 'Coming soon'}
            </span>
          </a>
        ))
      }
    </div>
  </div>
</Layout>
