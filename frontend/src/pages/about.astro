---
import Layout from '../layouts/Layout.astro';

const skills = [
  'TypeScript / Node.js',
  'Vue.js / Astro',
  'Python / FastAPI',
  'LangChain / RAG',
  'Computer Vision',
  'C# / .NET Core',
  'SQL / MongoDB',
  'Docker / CI/CD',
  'Testing (Playwright)'
];

const softSkills = [
  'Analytisches Denken',
  'Hohes Verantwortungsbewusstsein',
  'Lösungsorientierung',
  'Teamplayer',
  'Hands-on Mentalität'
];
---

<Layout title="Sinan.AI - Profil">
  <div class="max-w-6xl mx-auto px-4 py-12 md:py-16">
    <h1 class="text-4xl md:text-5xl font-bold mb-12 text-center animate-fade-in">
      <span class="bg-gradient-to-r from-blue-400 to-emerald-400 text-transparent bg-clip-text">
        Der Entwickler hinter dem Code
      </span>
    </h1>

    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-[minmax(180px,auto)] animate-fade-in-up"
    >
      <div
        class="md:col-span-1 bg-slate-900/50 border border-slate-800 p-6 rounded-3xl flex flex-col items-center text-center justify-center hover:border-emerald-500/30 transition-colors"
      >
        <div
          class="w-32 h-32 md:w-40 md:h-40 rounded-full border-4 border-slate-800 overflow-hidden mb-4 shadow-xl"
        >
          <img src="/image1.png" alt="Sinan Uçar" class="w-full h-full object-cover" />
        </div>
        <h3 class="text-xl font-bold text-white">Sinan Uçar</h3>
        <p class="text-emerald-400 text-sm font-mono mt-1">Dipl.-Inf.</p>
        <p class="text-slate-500 text-sm mt-4">
          Open for Remote
        </p>
      </div>

      <div
        class="md:col-span-2 bg-slate-900/50 border border-slate-800 p-8 rounded-3xl flex flex-col justify-center hover:border-slate-700 transition-colors"
      >
        <h2 class="text-2xl font-bold text-white mb-4">Code, Logik & Innovation</h2>
        <p class="text-slate-400 text-lg leading-relaxed space-y-4">
          Im Herzen bin ich <strong class="text-emerald-400">Informatiker</strong>. Seit meiner
          Diplomarbeit über Neuronale Netze (KNN) fasziniert mich die Kunst, komplexe mathematische
          Logik in sauberen, performanten Code zu übersetzen.
          <br /><br />
          In über <strong class="text-blue-400">15 Jahren Praxis</strong> habe ich gelernt, dass Theorie
          allein nicht reicht. Guter Code muss wartbar, stabil und skalierbar sein.
          <br /><br />
          <strong>Mein Ansatz heute:</strong> Ich nutze AI nicht als "Black Box", sondern integriere sie
          als präzises Werkzeug in meinen Full-Stack-Workflow.
        </p>
      </div>

      <div
        class="bg-slate-900/50 border border-slate-800 p-6 rounded-3xl hover:border-blue-500/30 transition-colors"
      >
        <h3 class="text-xl font-bold text-blue-400 mb-4">Mein Werkzeugkasten</h3>
        <div class="flex flex-wrap gap-2">
          {
            skills.map((skill) => (
              <span class="text-xs bg-slate-950 border border-slate-800 px-2 py-1 rounded text-slate-300">
                {skill}
              </span>
            ))
          }
        </div>
      </div>

      <div
        class="bg-gradient-to-br from-blue-900/20 to-slate-900 border border-slate-800 p-6 rounded-3xl hover:border-emerald-500/30 transition-colors"
      >
        <h3 class="text-xl font-bold text-emerald-400 mb-4">Arbeitsweise</h3>
        <ul class="space-y-2 text-slate-400 text-sm">
          {softSkills.map((s) => <li class="flex items-center gap-2">✅ {s}</li>)}
        </ul>
      </div>

      <div
        class="bg-gradient-to-br from-blue-900/20 to-slate-900 border border-slate-800 p-6 rounded-3xl hover:border-emerald-500/30 transition-colors"
      >
        <div class="max-w-2xl">
          <h3 class="text-2xl font-bold text-white mb-2">Sprachen</h3>
          <ul class="space-y-2 text-slate-400 text-sm">
            <li class="flex items-center gap-2">Deutsch</li>
            <li class="flex items-center gap-2">Englisch</li>
            <li class="flex items-center gap-2">Türkisch</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</Layout>
