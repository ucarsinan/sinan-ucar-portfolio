---
import type { Project, ProjectStatus } from '../data/projects';

interface Props {
  project: Project;
  lang?: 'de' | 'en';
}

const { project, lang = 'de' } = Astro.props;

const isEn = lang === 'en';

const title = isEn ? project.titleEn : project.title;
const tagline = isEn ? project.taglineEn : project.tagline;
const problem = isEn ? project.problemEn : project.problem;
const solution = isEn ? project.solutionEn : project.solution;
const result = isEn ? project.resultEn : project.result;

const statusLabel: Record<ProjectStatus, { de: string; en: string; color: string }> = {
  live: {
    de: 'Live',
    en: 'Live',
    color: 'text-emerald-400 border-emerald-500/30 bg-emerald-950/30'
  },
  'in-development': {
    de: 'In Entwicklung',
    en: 'In Development',
    color: 'text-blue-400 border-blue-500/30 bg-blue-950/30'
  },
  prototype: {
    de: 'Prototyp',
    en: 'Prototype',
    color: 'text-amber-400 border-amber-500/30 bg-amber-950/30'
  }
};

const status = statusLabel[project.status];
const statusText = isEn ? status.en : status.de;

const problemLabel = isEn ? 'Problem' : 'Problem';
const solutionLabel = isEn ? 'Solution' : 'Lösung';
const resultLabel = isEn ? 'Result' : 'Ergebnis';
---

<div
  class="bg-slate-900/50 border border-slate-800 rounded-3xl p-8 hover:border-slate-700 transition-all duration-300 group"
>
  <!-- Header -->
  <div class="flex items-start justify-between gap-4 mb-6">
    <div>
      <span class="text-xs font-mono text-slate-600 tracking-widest uppercase">
        Projekt {project.number}
      </span>
      <h2 class="text-2xl font-bold text-white mt-1 group-hover:text-emerald-300 transition-colors">
        {title}
      </h2>
      <p class="text-slate-500 text-sm mt-1">{tagline}</p>
    </div>
    <span
      class={`shrink-0 text-xs font-bold px-3 py-1 rounded-full border font-mono ${status.color}`}
    >
      {statusText}
    </span>
  </div>

  <!-- Stack Tags -->
  <div class="flex flex-wrap gap-2 mb-6">
    {
      project.stack.map((tag) => (
        <span class="text-xs font-mono text-slate-400 border border-slate-700/50 px-2 py-1 rounded bg-slate-800/50">
          {tag}
        </span>
      ))
    }
  </div>

  <!-- Problem / Solution / Result -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="bg-slate-950/50 border border-amber-500/10 rounded-xl p-4">
      <div class="text-xs font-bold text-amber-400 tracking-widest uppercase mb-2">
        {problemLabel}
      </div>
      <p class="text-slate-400 text-sm leading-relaxed">{problem}</p>
    </div>

    <div class="bg-slate-950/50 border border-blue-500/10 rounded-xl p-4">
      <div class="text-xs font-bold text-blue-400 tracking-widest uppercase mb-2">
        {solutionLabel}
      </div>
      <p class="text-slate-400 text-sm leading-relaxed">{solution}</p>
    </div>

    <div class="bg-slate-950/50 border border-emerald-500/10 rounded-xl p-4">
      <div class="text-xs font-bold text-emerald-400 tracking-widest uppercase mb-2">
        {resultLabel}
      </div>
      <p class="text-slate-400 text-sm leading-relaxed">{result}</p>
    </div>
  </div>

  <!-- Links -->
  {
    (project.demoUrl || project.githubUrl) && (
      <div class="flex gap-4 mt-6 pt-6 border-t border-slate-800">
        {project.demoUrl && (
          <a
            href={project.demoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-sm text-emerald-400 hover:text-emerald-300 transition-colors font-mono"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
              />
            </svg>
            {isEn ? 'View' : 'Ansehen'}
          </a>
        )}
        {project.githubUrl && (
          <a
            href={project.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-sm text-slate-400 hover:text-slate-300 transition-colors font-mono"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.38.6.11.82-.26.82-.58v-2.03c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.21.08 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 013-.4c1.02.005 2.04.14 3 .4 2.28-1.55 3.29-1.23 3.29-1.23.66 1.66.25 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58C20.57 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z" />
            </svg>
            GitHub
          </a>
        )}
      </div>
    )
  }
</div>
