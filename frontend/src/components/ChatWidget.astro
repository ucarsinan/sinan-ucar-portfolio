---
// 1. Sprache server-seitig ermitteln
const lang = Astro.currentLocale || 'de';

// 2. Texte basierend auf Sprache wählen
const initialMessage =
  lang === 'de'
    ? 'Hallo! Ich kenne Sinans Lebenslauf im Detail. Frag mich nach Skills, Projekten oder Erfahrung.'
    : "Hello! I know Sinan's resume in detail. Ask me about his skills, projects, or experience.";

const placeholderText = lang === 'de' ? 'Frage eingeben...' : 'Ask a question...';
---

<div
  id="chat-wrapper"
  data-lang={lang}
  class="w-full h-full flex flex-col bg-slate-900/80 backdrop-blur-md md:border md:border-slate-700/50 md:rounded-2xl shadow-2xl overflow-hidden relative transition-colors duration-300"
>
  <div
    class="flex-none bg-gradient-to-b from-slate-900/90 to-transparent p-4 z-10 border-b border-slate-800/50"
  >
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-2">
        <span class="relative flex h-3 w-3">
          <span
            id="status-ping"
            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
          ></span>
          <span id="status-dot" class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"
          ></span>
        </span>
        <span
          id="status-text"
          class="text-[10px] font-bold tracking-widest text-emerald-400 uppercase"
          >SYSTEM ONLINE</span
        >
      </div>
      <div class="text-[10px] text-slate-500 font-mono">AI-POWERED</div>
    </div>
  </div>

  <div id="chat-container" class="flex-grow overflow-y-auto p-4 flex flex-col gap-4 scroll-smooth">
    <div
      class="self-start max-w-[90%] bg-slate-800 border border-slate-700 text-slate-200 px-4 py-3 rounded-2xl rounded-tl-none text-sm shadow-md"
    >
      <div class="flex items-center gap-2 mb-1 opacity-70">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-[10px] font-bold tracking-wider text-emerald-400">AI CORE</span>
      </div>
      {initialMessage}
    </div>
  </div>

  <div class="flex-none p-4 bg-slate-900/90 z-20">
    <div
      class="relative flex items-center bg-slate-950 border border-slate-800 rounded-xl shadow-inner focus-within:border-blue-500/50 transition-colors"
    >
      <input
        type="text"
        id="user-input"
        name="message"
        autocomplete="off"
        aria-label={lang === 'de' ? 'Nachricht eingeben' : 'Enter message'}
        placeholder={placeholderText}
        class="w-full bg-transparent text-white px-4 py-3 text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 placeholder-slate-600 font-mono rounded-l-xl"
      />
      <button
        id="send-btn"
        aria-label={lang === 'de' ? 'Nachricht senden' : 'Send message'}
        class="mr-2 p-2 bg-blue-600 hover:bg-blue-500 text-white rounded-lg transition-colors flex items-center justify-center"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
          class="w-4 h-4"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"
          ></path>
        </svg>
      </button>
    </div>
  </div>
</div>

<script>
  import { marked } from 'marked';
  import DOMPurify from 'isomorphic-dompurify';
  const input = document.getElementById('user-input');
  const btn = document.getElementById('send-btn');
  const chatContainer = document.getElementById('chat-container');
  const statusText = document.getElementById('status-text');
  const statusDot = document.getElementById('status-dot');
  const statusPing = document.getElementById('status-ping');
  const chatWrapper = document.getElementById('chat-wrapper'); // Wrapper holen

  const API_URL = '/api/chat';

  function setStatus(state) {
    if (!statusText || !statusDot || !statusPing) return;
    if (state === 'starting') {
      statusText.innerText = 'SYSTEM STARTING...';
      statusText.className = 'text-[10px] font-bold tracking-widest text-yellow-400 uppercase';
      statusDot.className = 'relative inline-flex rounded-full h-3 w-3 bg-yellow-500';
      statusPing.classList.remove('hidden');
      statusPing.className =
        'animate-ping absolute inline-flex h-full w-full rounded-full bg-yellow-400 opacity-75';
    } else if (state === 'processing') {
      statusText.innerText = 'PROCESSING...';
      statusText.className = 'text-[10px] font-bold tracking-widest text-yellow-400 uppercase';
      statusDot.className = 'relative inline-flex rounded-full h-3 w-3 bg-yellow-500';
      statusPing.classList.remove('hidden');
      statusPing.className =
        'animate-ping absolute inline-flex h-full w-full rounded-full bg-yellow-400 opacity-75';
    } else if (state === 'error') {
      statusText.innerText = 'CONNECTION ERROR';
      statusText.className = 'text-[10px] font-bold tracking-widest text-red-400 uppercase';
      statusDot.className = 'relative inline-flex rounded-full h-3 w-3 bg-red-500';
      statusPing.classList.add('hidden');
    } else {
      statusText.innerText = 'SYSTEM ONLINE';
      statusText.className = 'text-[10px] font-bold tracking-widest text-emerald-400 uppercase';
      statusDot.className = 'relative inline-flex rounded-full h-3 w-3 bg-emerald-500';
      statusPing.classList.remove('hidden');
      statusPing.className =
        'animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75';
    }
  }

  function appendMessage(text, sender) {
    if (!chatContainer) return;
    const div = document.createElement('div');
    const isUser = sender === 'user';
    div.className = isUser
      ? 'self-end max-w-[85%] bg-blue-600/10 border border-blue-500/30 text-blue-100 px-4 py-3 rounded-2xl rounded-tr-none text-sm shadow-md animate-fade-in'
      : 'self-start max-w-[85%] bg-slate-800 border border-slate-700 text-slate-200 px-4 py-3 rounded-2xl rounded-tl-none text-sm shadow-md animate-fade-in';
    const label = isUser
      ? `<div class="flex items-center justify-end gap-2 mb-1 opacity-70"><span class="text-[10px] font-bold tracking-wider text-blue-400">YOU</span><span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span></div>`
      : `<div class="flex items-center gap-2 mb-1 opacity-70"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span><span class="text-[10px] font-bold tracking-wider text-emerald-400">AI CORE</span></div>`;
    let safeText = text;
    if (typeof text === 'object' && text !== null) {
      if (Array.isArray(text)) {
        safeText = text.map((item) => item.text || JSON.stringify(item)).join('\n');
      } else {
        safeText = JSON.stringify(text, null, 2);
      }
    }
    if (!safeText) safeText = 'Keine Antwort erhalten.';
    let contentHtml = safeText;
    if (!isUser) {
      // @ts-ignore
      contentHtml = DOMPurify.sanitize(marked.parse(safeText));
    }
    div.innerHTML = `${label}<div class="leading-relaxed markdown-content ${isUser ? '' : 'text-slate-300'}">${contentHtml}</div>`;
    chatContainer.appendChild(div);
    chatContainer.scrollTop = chatContainer.scrollHeight;
  }

  async function sendMessage(msgText: string, retryCount = 0) {
    if (!input || !btn) return;
    (input as HTMLInputElement).disabled = true;
    (btn as HTMLButtonElement).disabled = true;
    setStatus('processing');

    const currentLang = chatWrapper?.getAttribute('data-lang') || 'de';

    try {
      const res = await fetch(API_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: msgText, language: currentLang })
      });

      if ((res.status === 502 || res.status === 503) && retryCount < 8) {
        if (retryCount === 0) {
          appendMessage(
            currentLang === 'de'
              ? 'KI-System startet (Cold Start). Bitte warte ca. 1–2 Minuten...'
              : 'AI system starting (cold start). Please wait 1–2 minutes...',
            'ai'
          );
          setStatus('starting');
        }
        await new Promise((r) => setTimeout(r, 15_000));
        await sendMessage(msgText, retryCount + 1);
        return;
      }

      if (!res.ok) throw new Error(`Status ${res.status}`);
      const data = await res.json();
      appendMessage(data.reply || 'Keine Antwort erhalten.', 'ai');
      setStatus('online');
    } catch {
      appendMessage(
        currentLang === 'de'
          ? 'Backend nicht erreichbar. Bitte Seite neu laden.'
          : 'Backend unreachable. Please reload the page.',
        'ai'
      );
      setStatus('error');
    } finally {
      (input as HTMLInputElement).disabled = false;
      (btn as HTMLButtonElement).disabled = false;
      (input as HTMLInputElement).focus();
    }
  }

  function handleSend() {
    // @ts-ignore
    const msg = (input as HTMLInputElement).value.trim();
    if (!msg) return;
    (input as HTMLInputElement).value = '';
    appendMessage(msg, 'user');
    sendMessage(msg);
  }

  if (btn) btn.addEventListener('click', handleSend);
  if (input)
    input.addEventListener('keypress', (e) => {
      if ((e as KeyboardEvent).key === 'Enter') handleSend();
    });
</script>

<style is:global>
  .markdown-content strong {
    font-weight: 700;
    color: #34d399;
  }
  .markdown-content ul {
    list-style-type: disc;
    padding-left: 1.5em;
    margin-top: 0.5em;
    margin-bottom: 0.5em;
  }
  .markdown-content li {
    margin-bottom: 0.25em;
  }
  .markdown-content p {
    margin-bottom: 0.75em;
  }
  .markdown-content p:last-child {
    margin-bottom: 0;
  }
</style>
