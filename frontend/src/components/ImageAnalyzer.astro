---
const { lang = 'de' } = Astro.props;
const API_URL = import.meta.env.PUBLIC_API_URL;

const t = {
  de: {
    title: "Vision Analyse",
    desc: "Lade einen Screenshot hoch. Die KI analysiert UX, Design und Code.",
    drop: "Bild hierhin ziehen oder klicken",
    btn: "Analysieren",
    result: "Analyse Ergebnis:",
    techLabel: "Technik:",
    tech: "Google Gemini Vision Model. Lädt Bilder hoch, encodiert sie zu Base64 und analysiert UI/UX-Elemente semantisch.",
    score: "Usability Score",
    feedback: "Design Feedback",
    improvements: "Verbesserungen",
    code: "Tailwind Snippet",
    imp_positive: "Positiv",
    imp_neutral: "Neutral",
    imp_negative: "Negativ"
  },
  en: {
    title: "Vision Analysis",
    desc: "Upload a screenshot. The AI analyzes UX, design, and code quality.",
    drop: "Drag & drop image here or click",
    btn: "Analyze",
    result: "Analysis Result:",
    techLabel: "Tech Stack:",
    tech: "Google Gemini Vision Model. Uploads images, encodes them to Base64, and semantically analyzes UI/UX elements.",
    score: "Usability Score",
    feedback: "Design Feedback",
    improvements: "Improvements",
    code: "Tailwind Snippet",
    imp_positive: "Positive",
    imp_neutral: "Neutral",
    imp_negative: "Negative"
  }
};

const text = lang === 'en' ? t.en : t.de;
---



<div class="bg-slate-800 p-6 rounded-2xl border border-slate-700 shadow-xl h-full flex flex-col">
  <h3 class="text-xl font-bold text-white mb-2 flex items-center gap-2">
    👁️ {text.title}
  </h3>
  <p class="text-slate-400 text-sm mb-4">
    {text.desc}
  </p>

  <div class="flex-grow flex flex-col gap-4">
    <div 
      id={`drop-zone-${lang}`}
      class="relative w-full h-48 border-2 border-dashed border-slate-600 rounded-xl hover:border-blue-500 hover:bg-slate-700/50 transition-colors flex flex-col justify-center items-center cursor-pointer group overflow-hidden bg-slate-900/50"
    >
      <input type="file" id={`file-input-${lang}`} accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
      
      <div id={`placeholder-${lang}`} class="text-center p-4 transition-opacity duration-300">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-slate-500 mx-auto mb-2 group-hover:text-blue-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <p class="text-slate-400 text-sm font-medium">{text.drop}</p>
        <p class="text-slate-600 text-xs mt-1">PNG, JPG (max 4MB)</p>
      </div>

      <img id={`image-preview-${lang}`} alt="" class="absolute inset-0 w-full h-full object-contain bg-slate-900 hidden z-0 p-2" />
    </div>

    <button 
      id={`vision-btn-${lang}`}
      disabled
      class="w-full bg-purple-600 hover:bg-purple-500 disabled:bg-slate-700 disabled:text-slate-500 disabled:cursor-not-allowed text-white font-medium py-2 px-4 rounded-lg transition-colors flex justify-center items-center gap-2 mt-auto"
    >
      <span>{text.btn}</span>
      <svg id={`vision-spinner-${lang}`} class="animate-spin h-4 w-4 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    </button>
  </div>

  <div id={`vision-result-${lang}`} class="hidden mt-6 pt-4 border-t border-slate-700 animate-fade-in flex flex-col gap-4">
    <div class="flex items-center justify-between">
      <h4 class="text-sm font-bold text-purple-400 uppercase tracking-wide">{text.result}</h4>
      <div id={`impression-badge-${lang}`} class="px-3 py-1 rounded-full text-xs font-bold bg-slate-800 text-slate-300 border border-slate-600">
        Neutral
      </div>
    </div>
    
    <div class="grid grid-cols-2 gap-4">
      <div class="bg-slate-900/50 p-4 rounded-lg border border-slate-700/50">
         <h5 class="text-xs text-slate-400 uppercase tracking-wider mb-1">{text.score}</h5>
         <div class="flex items-baseline gap-1">
           <span id={`score-value-${lang}`} class="text-3xl font-extrabold text-white">0</span>
           <span class="text-slate-500 font-medium">/ 10</span>
         </div>
         <div class="w-full bg-slate-800 rounded-full h-1.5 mt-3">
           <div id={`score-bar-${lang}`} class="bg-gradient-to-r from-red-500 via-yellow-500 to-green-500 h-1.5 rounded-full" style="width: 0%"></div>
         </div>
      </div>
    </div>

    <div class="bg-slate-900/50 p-4 rounded-lg border border-slate-700/50 text-slate-300 text-sm leading-relaxed">
       <h5 class="text-xs text-slate-400 uppercase tracking-wider mb-2">{text.feedback}</h5>
       <p id={`feedback-text-${lang}`}></p>
    </div>

    <div class="bg-slate-900/50 p-4 rounded-lg border border-slate-700/50">
       <h5 class="text-xs text-slate-400 uppercase tracking-wider mb-2">{text.improvements}</h5>
       <ul id={`improvements-list-${lang}`} class="list-disc filter drop-shadow-sm pl-5 text-sm text-slate-300 space-y-1">
       </ul>
    </div>
    
    <div id={`code-container-${lang}`} class="hidden bg-slate-900/80 p-4 rounded-lg border border-slate-700 h-max">
       <div class="flex items-center justify-between mb-2">
         <h5 class="text-xs text-slate-400 uppercase tracking-wider">{text.code}</h5>
         <span class="text-[10px] text-blue-400 bg-blue-400/10 px-2 py-0.5 rounded border border-blue-400/20">Tailwind CSS</span>
       </div>
       <pre class="text-xs text-green-400 font-mono overflow-x-auto custom-scrollbar p-2 bg-black/50 rounded"><code id={`tailwind-code-${lang}`}></code></pre>
    </div>
    <div class="mt-auto pt-6 border-t border-slate-700/50 text-[10px] text-slate-500 uppercase tracking-widest flex items-center gap-2">
      <span class="text-purple-500/50">●</span>
      <strong class="text-slate-400 font-semibold">{text.techLabel}</strong> {text.tech}
    </div>
  </div>
</div>

<script define:vars={{ API_URL, lang, text }}>
  const fileInput = document.getElementById(`file-input-${lang}`);
  const placeholder = document.getElementById(`placeholder-${lang}`);
  const preview = document.getElementById(`image-preview-${lang}`);
  const btn = document.getElementById(`vision-btn-${lang}`);
  const spinner = document.getElementById(`vision-spinner-${lang}`);
  const resultArea = document.getElementById(`vision-result-${lang}`);
  
  // Element Refs
  const impressionBadge = document.getElementById(`impression-badge-${lang}`);
  const scoreValue = document.getElementById(`score-value-${lang}`);
  const scoreBar = document.getElementById(`score-bar-${lang}`);
  const feedbackText = document.getElementById(`feedback-text-${lang}`);
  const improvementsList = document.getElementById(`improvements-list-${lang}`);
  const codeContainer = document.getElementById(`code-container-${lang}`);
  const tailwindCode = document.getElementById(`tailwind-code-${lang}`);

  let selectedFile = null;

  fileInput.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (!file) return;
    selectedFile = file;
    const reader = new FileReader();
    reader.onload = (e) => {
      preview.src = e.target.result;
      preview.classList.remove('hidden');
      placeholder.classList.add('hidden');
      btn.disabled = false;
    };
    reader.readAsDataURL(file);
  });

  btn.addEventListener('click', async () => {
    if (!selectedFile) return;

    btn.disabled = true;
    spinner.classList.remove('hidden');
    resultArea.classList.add('hidden');
    
    const formData = new FormData();
    formData.append('file', selectedFile);
    formData.append('language', lang);

    try {
      const res = await fetch(`${API_URL}/api/vision`, {
        method: 'POST',
        body: formData
      });

      const data = await res.json();
      
      if (data && !data.error) {
        // Impression Badge
        impressionBadge.className = "px-3 py-1 rounded-full text-xs font-bold border";
        if(data.impression === 'positive') {
          impressionBadge.classList.add('bg-green-500/20', 'text-green-400', 'border-green-500/30');
          impressionBadge.textContent = text.imp_positive;
        } else if(data.impression === 'negative') {
          impressionBadge.classList.add('bg-red-500/20', 'text-red-400', 'border-red-500/30');
          impressionBadge.textContent = text.imp_negative;
        } else {
           impressionBadge.classList.add('bg-slate-500/20', 'text-slate-400', 'border-slate-500/30');
           impressionBadge.textContent = text.imp_neutral;
        }

        // Score
        const score = data.usability_score || 0;
        scoreValue.textContent = score;
        scoreBar.style.width = `${(score / 10) * 100}%`;

        // Texts
        feedbackText.textContent = data.design_feedback || '';
        
        // Improvements Loop
        improvementsList.innerHTML = '';
        if(data.improvements && Array.isArray(data.improvements)) {
          data.improvements.forEach(imp => {
            const li = document.createElement('li');
            li.textContent = imp;
            improvementsList.appendChild(li);
          });
        }

        // Code block
        if(data.tailwind_code && data.tailwind_code.trim() !== '') {
          tailwindCode.textContent = data.tailwind_code.replace(/```[a-z]*\n?/g, '').trim();
          codeContainer.classList.remove('hidden');
        } else {
          codeContainer.classList.add('hidden');
        }

        resultArea.classList.remove('hidden');
      } else {
        feedbackText.textContent = "Server Error: " + (data.error || "Unknown error");
        resultArea.classList.remove('hidden');
      }
    } catch (e) {
      console.error(e);
      feedbackText.textContent = "Error: " + e.message;
      resultArea.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      spinner.classList.add('hidden');
    }
  });
</script>

<style>
  .custom-scrollbar::-webkit-scrollbar { width: 6px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: rgba(30, 41, 59, 0.5); }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(71, 85, 105, 0.8); border-radius: 3px; }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(148, 163, 184, 0.8); }
  :global(.prose h1), :global(.prose h2), :global(.prose h3) { color: #e2e8f0; margin-top: 1.5em; margin-bottom: 0.5em; font-weight: 700; }
  :global(.prose strong) { color: #60a5fa; font-weight: 700; }
  :global(.prose ul) { list-style-type: disc; padding-left: 1.5em; margin-bottom: 1em; }
  :global(.prose pre) { background-color: #0f172a; border: 1px solid #334155; padding: 1em; border-radius: 0.5em; }
</style>