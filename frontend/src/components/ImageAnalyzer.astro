---
const API_URL = import.meta.env.PUBLIC_API_URL;
---

<div class="bg-slate-800 p-6 rounded-2xl border border-slate-700 shadow-xl h-full flex flex-col">
  <h3 class="text-xl font-bold text-white mb-2 flex items-center gap-2">
    👁️ Vision Analyse
  </h3>
  <p class="text-slate-400 text-sm mb-4">
    Lade einen Screenshot hoch. Die KI analysiert UX, Design und Code.
  </p>

  <div class="flex-grow flex flex-col gap-4">
    
    <div 
      id="drop-zone"
      class="relative w-full h-48 border-2 border-dashed border-slate-600 rounded-xl hover:border-blue-500 hover:bg-slate-700/50 transition-all flex flex-col justify-center items-center cursor-pointer group overflow-hidden bg-slate-900/50"
    >
      <input type="file" id="file-input" accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
      
      <div id="placeholder" class="text-center p-4 transition-opacity duration-300">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-slate-500 mx-auto mb-2 group-hover:text-blue-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <p class="text-slate-400 text-sm font-medium">Bild hierhin ziehen oder klicken</p>
        <p class="text-slate-600 text-xs mt-1">PNG, JPG (max 4MB)</p>
      </div>

      <img id="image-preview" class="absolute inset-0 w-full h-full object-contain bg-slate-900 hidden z-0 p-2" />
    </div>

    <button 
      id="vision-btn"
      disabled
      class="w-full bg-purple-600 hover:bg-purple-500 disabled:bg-slate-700 disabled:text-slate-500 disabled:cursor-not-allowed text-white font-medium py-2 px-4 rounded-lg transition-colors flex justify-center items-center gap-2"
    >
      <span>Analysieren</span>
      <svg id="vision-spinner" class="animate-spin h-4 w-4 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    </button>
  </div>

  <div id="vision-result" class="hidden mt-6 pt-4 border-t border-slate-700 animate-fade-in">
    <h4 class="text-sm font-bold text-purple-400 mb-2 uppercase tracking-wide">Analyse Ergebnis:</h4>
    <div id="markdown-content" class="prose prose-invert prose-sm max-w-none text-slate-300 bg-slate-900/50 p-4 rounded-lg border border-slate-700/50 max-h-60 overflow-y-auto custom-scrollbar">
      ...
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js" is:inline></script>

<script define:vars={{ API_URL }}>
  const fileInput = document.getElementById('file-input');
  const placeholder = document.getElementById('placeholder');
  const preview = document.getElementById('image-preview');
  const btn = document.getElementById('vision-btn');
  const spinner = document.getElementById('vision-spinner');
  const resultArea = document.getElementById('vision-result');
  const markdownContent = document.getElementById('markdown-content');

  let selectedFile = null;

  // 1. Datei Auswahl Handler
  fileInput.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (!file) return;

    selectedFile = file;
    
    // Preview anzeigen
    const reader = new FileReader();
    reader.onload = (e) => {
      preview.src = e.target.result;
      preview.classList.remove('hidden'); // Bild zeigen
      placeholder.classList.add('hidden'); // Text verstecken
      btn.disabled = false; // Button aktivieren
    };
    reader.readAsDataURL(file);
  });

  // 2. Analyse Handler
  btn.addEventListener('click', async () => {
    if (!selectedFile) return;

    // UI Loading State
    btn.disabled = true;
    spinner.classList.remove('hidden');
    resultArea.classList.add('hidden');
    
    const formData = new FormData();
    formData.append('file', selectedFile);

    try {
      const res = await fetch(`${API_URL}/api/vision`, {
        method: 'POST',
        body: formData
      });

      const data = await res.json();
      
      if (data.analysis) {
        // Markdown parsen (dank marked.js)
        // @ts-ignore
        markdownContent.innerHTML = marked.parse(data.analysis);
        resultArea.classList.remove('hidden');
      } else {
        alert("Keine Analyse erhalten.");
      }

    } catch (e) {
      console.error(e);
      alert("Fehler bei der Vision-Analyse: " + e.message);
    } finally {
      btn.disabled = false;
      spinner.classList.add('hidden');
    }
  });
</script>

<style>
  /* Hübscher Scrollbar für den Textbereich */
  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: rgba(30, 41, 59, 0.5);
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(71, 85, 105, 0.8);
    border-radius: 3px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(148, 163, 184, 0.8);
  }
</style>