<div
  id="cookie-banner"
  class="fixed bottom-4 right-4 max-w-sm w-[calc(100%-2rem)] bg-slate-900/95 backdrop-blur-md border border-slate-700 p-6 rounded-2xl shadow-2xl z-50 transform translate-y-full opacity-0 transition-[transform,opacity] duration-500 motion-reduce:transition-none"
>
  <div class="flex items-start gap-4">
    <div class="p-2 bg-blue-500/10 rounded-lg text-blue-400">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="w-6 h-6"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"
        ></path>
      </svg>
    </div>

    <div class="space-y-2">
      <h3 class="font-bold text-white text-sm">AI & Datenschutz</h3>
      <p class="text-xs text-slate-400 leading-relaxed">
        Diese Seite nutzt <strong>Künstliche Intelligenz (Google Gemini)</strong>. Wenn Sie den Chat
        oder die Bildanalyse nutzen, werden Eingaben an Google übermittelt. Es werden keine
        Tracking-Cookies für Werbung gesetzt.
      </p>
      <div class="flex gap-4 pt-2">
        <a href="/privacy" class="text-xs text-slate-500 hover:text-white underline">Details</a>
        <button
          id="accept-cookies"
          class="text-xs bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-1.5 px-4 rounded transition-colors"
        >
          Alles klar
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  // Check, ob schon bestätigt wurde
  const banner = document.getElementById('cookie-banner');
  const btn = document.getElementById('accept-cookies');
  const consent = localStorage.getItem('sinan-ai-consent');

  if (!consent && banner) {
    // Kurz warten, dann einblenden
    setTimeout(() => {
      banner.classList.remove('translate-y-full', 'opacity-0');
    }, 1000);
  }

  btn?.addEventListener('click', () => {
    localStorage.setItem('sinan-ai-consent', 'true');
    banner?.classList.add('translate-y-full', 'opacity-0');
  });
</script>
