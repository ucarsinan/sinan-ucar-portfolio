---
const { lang = 'de' } = Astro.props;
const API_URL = import.meta.env.PUBLIC_API_URL;

const t = {
  de: {
    title: "Portfolio Agent",
    desc: "Ein autonomer KI-Agent mit Tools. Er kann rechnen, die Zeit lesen und Projekte durchsuchen.",
    placeholder: "Frage den Agenten (z.B. 'Wie spät ist es?' oder 'Berechne 42*1337')",
    btn: "Fragen",
    thinking: "Überlege...",
    agent_label: "Smarter Agent",
    results: "Agenten-Antwort:"
  },
  en: {
    title: "Portfolio Agent",
    desc: "An autonomous AI agent with tools. He can calculate, tell the time, and search projects.",
    placeholder: "Ask the agent (e.g., 'What time is it?' or 'Calculate 42*1337')",
    btn: "Ask",
    thinking: "Thinking...",
    agent_label: "Smart Agent",
    results: "Agent Output:"
  }
};

const text = lang === 'en' ? t.en : t.de;
---

<div
  class="bg-slate-800 p-6 rounded-2xl border border-slate-700 shadow-xl h-full flex flex-col"
  data-api-url={API_URL}
  data-lang={lang}
  data-thinking={text.thinking}
  data-btn={text.btn}
>
  <h3 class="text-xl font-bold text-white mb-2 flex items-center gap-3">
    <div class="p-2 bg-green-500/20 rounded-lg text-green-400">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
      </svg>
    </div>
    {text.title}
  </h3>
  <p class="text-slate-400 text-sm mb-6">
    {text.desc}
  </p>

  <div class="flex-grow flex flex-col gap-4">
    <div class="relative">
      <textarea
        id={`agent-input-${lang}`}
        name="agent-message"
        aria-label={lang === 'de' ? 'Frage an den Agenten' : 'Ask the agent'}
        placeholder={text.placeholder}
        class="w-full bg-slate-900 border border-slate-700 rounded-lg p-3 text-slate-200 text-sm focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:border-transparent focus-visible:outline-none resize-none min-h-[100px]"
      ></textarea>
    </div>

    <button 
      id={`agent-btn-${lang}`}
      class="w-full bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 px-4 rounded-lg transition-colors flex justify-center items-center gap-2"
    >
      <span>{text.btn}</span>
      <svg id={`agent-spinner-${lang}`} class="animate-spin h-5 w-5 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    </button>
  </div>

  <div id={`agent-result-area-${lang}`} class="hidden mt-6 pt-6 border-t border-slate-700 animate-fade-in">
    <div class="flex items-center gap-2 mb-3">
      <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
      <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest">{text.results}</h4>
    </div>
    
    <div class="bg-black/40 p-5 rounded-2xl border border-slate-700/50 relative overflow-hidden group">
      <div class="absolute top-0 left-0 w-1 h-full bg-green-500/50 group-hover:bg-green-500 transition-colors"></div>
      <div id={`agent-reply-${lang}`} class="agent-prose text-slate-200 text-sm leading-relaxed"></div>
    </div>

    <div class="mt-auto pt-6 border-t border-slate-700/50 text-[10px] text-slate-500 uppercase tracking-widest flex items-center gap-2">
      <span class="text-green-500/50">●</span>
      <strong class="text-slate-400 font-semibold">Tech Level 6:</strong> ASynchronous Tool-Calling, Gemini Flash, LangChain, FastAPI
    </div>
  </div>
</div>

<script>
  import { marked } from 'marked';
  import DOMPurify from 'isomorphic-dompurify';

  document.querySelectorAll<HTMLElement>('[data-lang]').forEach((container) => {
    const API_URL = container.dataset.apiUrl!;
    const lang = container.dataset.lang!;
    const thinkingText = container.dataset.thinking!;
    const btnText = container.dataset.btn!;

    const input = container.querySelector<HTMLTextAreaElement>(`#agent-input-${lang}`)!;
    const btn = container.querySelector<HTMLButtonElement>(`#agent-btn-${lang}`)!;
    const spinner = container.querySelector<HTMLElement>(`#agent-spinner-${lang}`)!;
    const resultArea = container.querySelector<HTMLElement>(`#agent-result-area-${lang}`)!;
    const replyText = container.querySelector<HTMLElement>(`#agent-reply-${lang}`)!;

    btn.addEventListener('click', async () => {
      const message = input.value.trim();
      if (!message) return;

      btn.disabled = true;
      spinner.classList.remove('hidden');
      btn.querySelector('span')!.textContent = thinkingText;

      try {
        const res = await fetch(`${API_URL}/api/agent`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message, language: lang })
        });

        const data = await res.json();

        if (data.reply) {
          let replyContent = '';
          if (Array.isArray(data.reply)) {
            replyContent = data.reply
              .filter((block: { type: string }) => block.type === 'text')
              .map((block: { text: string }) => block.text)
              .join('\n');
          } else {
            replyContent = data.reply;
          }
          replyText.innerHTML = DOMPurify.sanitize(await marked.parse(replyContent));
          resultArea.classList.remove('hidden');
          resultArea.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      } catch (e) {
        console.error(e);
        replyText.textContent = "Fehler: " + (e as Error).message;
        resultArea.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        spinner.classList.add('hidden');
        btn.querySelector('span')!.textContent = btnText;
      }
    });

    input.addEventListener('keydown', (e: Event) => {
      const ke = e as KeyboardEvent;
      if ((ke.metaKey || ke.ctrlKey) && ke.key === 'Enter') {
        btn.click();
      }
    });
  });
</script>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 0.4s ease-out forwards;
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in { animation: none; }
  }

  .agent-prose p { margin-bottom: 0.75rem; }
  .agent-prose strong { color: white; font-weight: 700; }
  .agent-prose em { color: rgb(167 243 208); font-style: italic; }
  .agent-prose ul { list-style-type: disc; padding-left: 1.25rem; margin-bottom: 0.75rem; }
  .agent-prose ol { list-style-type: decimal; padding-left: 1.25rem; margin-bottom: 0.75rem; }
  .agent-prose li { margin-bottom: 0.25rem; }
  .agent-prose code { background: rgb(15 23 42); color: rgb(52 211 153); padding: 0.1rem 0.35rem; border-radius: 0.25rem; font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; }
  .agent-prose h1, .agent-prose h2, .agent-prose h3 { color: white; font-weight: 700; margin: 1rem 0 0.5rem; }
</style>
