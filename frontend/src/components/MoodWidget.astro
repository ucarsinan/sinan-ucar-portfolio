---
// MoodWidget.astro
const API_URL = import.meta.env.PUBLIC_API_URL;
---

<div class="bg-slate-800 p-6 rounded-2xl border border-slate-700 shadow-xl max-w-lg mx-auto my-10">
  <h3 class="text-xl font-bold text-white mb-2 flex items-center gap-2">
    🎭 AI Stimmungs-Barometer
  </h3>
  <p class="text-slate-400 text-sm mb-4">
    Schreibe eine Nachricht und lass die KI analysieren, wie sie wirkt.
  </p>

  <div class="flex flex-col gap-3">
    <textarea 
      id="mood-input" 
      rows="3" 
      placeholder="Gib hier deinen Text ein (z.B. eine E-Mail oder Chat-Nachricht)..."
      class="w-full bg-slate-900 text-white rounded-lg p-3 border border-slate-700 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition resize-none"
    ></textarea>

    <button 
      id="analyze-btn"
      class="bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 px-4 rounded-lg transition-colors flex justify-center items-center gap-2"
    >
      <span>Analysieren</span>
      <svg id="spinner" class="animate-spin h-4 w-4 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    </button>
  </div>

  <div id="result-area" class="hidden mt-6 pt-4 border-t border-slate-700 animate-fade-in">
    
    <div class="flex justify-between items-center mb-2">
      <span class="text-slate-400 text-sm">Erkannte Emotion:</span>
      <span id="emotion-badge" class="px-2 py-1 rounded text-xs font-bold uppercase tracking-wider bg-gray-700 text-gray-300">
        Neutral
      </span>
    </div>

    <div class="w-full bg-slate-900 rounded-full h-2.5 mb-4 overflow-hidden relative">
      <div class="absolute left-1/2 top-0 bottom-0 w-0.5 bg-slate-600"></div>
      <div id="score-bar" class="bg-blue-500 h-2.5 rounded-full transition-all duration-1000 ease-out" style="width: 50%"></div>
    </div>
    <div class="flex justify-between text-[10px] text-slate-500 uppercase font-mono">
      <span>Negativ</span>
      <span>Positiv</span>
    </div>

    <div class="mt-4 bg-slate-900/50 p-3 rounded border border-slate-700/50">
      <p class="text-xs text-blue-400 font-bold mb-1">💡 KI TIPP:</p>
      <p id="suggestion-text" class="text-sm text-slate-300 italic">...</p>
    </div>
  </div>
</div>

<script define:vars={{ API_URL }}>
  const input = document.getElementById('mood-input');
  const btn = document.getElementById('analyze-btn');
  const spinner = document.getElementById('spinner');
  const resultArea = document.getElementById('result-area');
  const emotionBadge = document.getElementById('emotion-badge');
  const scoreBar = document.getElementById('score-bar');
  const suggestionText = document.getElementById('suggestion-text');

  btn.addEventListener('click', async () => {
    const text = input.value.trim();
    if (!text) return;

    // UI Reset
    btn.disabled = true;
    spinner.classList.remove('hidden');
    resultArea.classList.add('hidden');

    try {
      // Fetch an dein Backend
      const res = await fetch(`${API_URL}/api/analyze`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text })
      });

      const data = await res.json();

      if (data.error) throw new Error(data.error);

      // Daten anzeigen
      showResult(data);

    } catch (e) {
      console.error(e);
      alert("Fehler bei der Analyse: " + e.message);
    } finally {
      btn.disabled = false;
      spinner.classList.add('hidden');
    }
  });

  function showResult(data) {
    // 1. Emotion Badge Farbe
    const colors = {
      'freude': 'bg-green-500/20 text-green-400 border border-green-500/50',
      'wut': 'bg-red-500/20 text-red-400 border border-red-500/50',
      'angst': 'bg-purple-500/20 text-purple-400 border border-purple-500/50',
      'trauer': 'bg-blue-500/20 text-blue-400 border border-blue-500/50',
      'neutral': 'bg-gray-500/20 text-gray-400 border border-gray-500/50'
    };
    emotionBadge.className = `px-2 py-1 rounded text-xs font-bold uppercase tracking-wider ${colors[data.emotion] || colors['neutral']}`;
    emotionBadge.innerText = data.emotion;

    // 2. Score Bar (Mapping von -1...1 auf 0...100%)
    // -1 -> 0%, 0 -> 50%, 1 -> 100%
    const percentage = ((data.score + 1) / 2) * 100;
    
    // Farbe des Balkens je nach Score
    let barColor = 'bg-gray-500';
    if (data.score > 0.3) barColor = 'bg-green-500';
    else if (data.score < -0.3) barColor = 'bg-red-500';
    else barColor = 'bg-blue-400';

    scoreBar.className = `h-2.5 rounded-full transition-all duration-1000 ease-out ${barColor}`;
    scoreBar.style.width = `${percentage}%`;

    // 3. Tipp
    suggestionText.innerText = data.suggestion;

    // Einblenden
    resultArea.classList.remove('hidden');
  }
</script>